# ============================================================================
# Price Monitor — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ============================================================================

# --- Database ---------------------------------------------------------------
DB_BACKEND=postgres
POSTGRES_USER=price
POSTGRES_DB=pricemonitor
# Use a STRONG password here, not the default. The DB binds to 127.0.0.1 only
# (see docker-compose) — not reachable from the internet.
POSTGRES_PASSWORD=change-me-to-a-long-random-string
DATABASE_URL=postgresql://price:change-me-to-a-long-random-string@db:5432/pricemonitor

# --- Public hosting (Caddy reverse proxy + HTTPS) ---------------------------
# The domain that points at this host. Used by Caddy for the TLS certificate.
# Only needed when running:  docker compose --profile public up -d
APP_DOMAIN=prices.example.com

# --- App / sessions ---------------------------------------------------------
# Random secret for signing session cookies. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-generate-a-random-48-byte-token
# Public base URL of the app (used for OIDC redirect + CORS). MUST be https.
APP_BASE_URL=https://prices.example.com
# Set to 0 ONLY for local http testing; must be 1 (default) in production.
COOKIE_SECURE=1
TZ=Europe/Athens

# --- Authentication (external OIDC identity provider) -----------------------
# Leave OIDC_ISSUER blank to run in single-user/local mode (no login).
#
# Google:   OIDC_ISSUER=https://accounts.google.com
# Auth0:    OIDC_ISSUER=https://YOUR_TENANT.auth0.com
# Supabase: OIDC_ISSUER=https://YOUR_PROJECT.supabase.co/auth/v1
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile

# --- Who may sign in (optional allow-list) ----------------------------------
# If BOTH are blank, anyone with an account at the provider can log in.
# Restrict to specific people:
OIDC_ALLOWED_EMAILS=you@example.com,partner@example.com
# …or to an entire domain (e.g. a Google Workspace):
OIDC_ALLOWED_DOMAIN=
